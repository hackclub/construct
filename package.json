		"lint": "eslint . && prettier --check .",
		"format": "prettier --write .",
		"db:push": "drizzle-kit push",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate --config ./drizzle.config.ts",
		"db:studio": "drizzle-kit studio"
	},
	"devDependencies": {
